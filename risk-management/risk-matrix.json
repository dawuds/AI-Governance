{
  "title": "AI Risk Assessment Matrix",
  "description": "Standard 5x5 risk assessment matrix mapping likelihood against impact to determine risk level.",
  "version": "1.0",
  "axes": {
    "likelihood": {
      "label": "Likelihood",
      "scale": [
        { "score": 1, "label": "Rare" },
        { "score": 2, "label": "Unlikely" },
        { "score": 3, "label": "Possible" },
        { "score": 4, "label": "Likely" },
        { "score": 5, "label": "Almost Certain" }
      ]
    },
    "impact": {
      "label": "Impact",
      "scale": [
        { "score": 1, "label": "Negligible" },
        { "score": 2, "label": "Minor" },
        { "score": 3, "label": "Moderate" },
        { "score": 4, "label": "Major" },
        { "score": 5, "label": "Critical" }
      ]
    }
  },
  "riskLevels": [
    { "id": "critical", "label": "Critical", "color": "#7F1D1D", "scoreRange": [20, 25], "description": "Immediate action required. Escalate to board. Consider system suspension." },
