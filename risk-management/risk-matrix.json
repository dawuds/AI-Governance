    { "id": "medium", "label": "Medium", "color": "#F59E0B", "scoreRange": [6, 11], "description": "Risk owner manages. Treatment plan with defined timeline." },
    { "id": "low", "label": "Low", "color": "#10B981", "scoreRange": [2, 5], "description": "Accept with documentation. Monitor in regular review cycle." },
    { "id": "negligible", "label": "Negligible", "color": "#6B7280", "scoreRange": [1, 1], "description": "Accept. Include in regular review." }
  ],
  "matrix": [
